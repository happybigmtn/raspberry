digraph GenesisOnboardingFlow {
    graph [
        goal="Genesis Onboarding Flow\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `CLAUDE.md`\n- `genesis/plans/001-master-plan.md`\n\nCurrent frontier tasks:\n- Make sure the CLI surface operators run actually exposes `fabro synth`\n- Fix genesis/create runtime handoff so generated workflows validate without local prompt shims\n- Add validation step after genesis that confirms package health\n- Test on an unfamiliar open-source repo\n- Write operator quickstart documentation\n\nRequired durable artifacts:\n- `outputs/genesis-onboarding-flow/spec.md`\n- `outputs/genesis-onboarding-flow/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: kimi-k2.5; provider: kimi; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: minimax; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@malinka/prompts/bootstrap/genesis-onboarding-flow/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@malinka/prompts/bootstrap/genesis-onboarding-flow/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@malinka/prompts/bootstrap/genesis-onboarding-flow/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="true", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

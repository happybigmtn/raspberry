digraph PerformanceMeasurementAndOptimization {
    graph [
        goal="Performance Measurement and Optimization\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `CLAUDE.md`\n- `genesis/plans/001-master-plan.md`\n\nCurrent frontier tasks:\n- Define operational KPIs and baseline targets\n- Instrument autodev cycle with timing spans\n- Add cost estimation per provider per cycle\n- Add failure classification metrics\n- Build metrics summary in raspberry status output\n- Establish baselines from live rXMRbro runs\n\nRequired durable artifacts:\n- `outputs/performance-measurement-and-optimization/spec.md`\n- `outputs/performance-measurement-and-optimization/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: kimi-k2.5; provider: kimi; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: minimax; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@malinka/prompts/bootstrap/performance-measurement-and-optimization/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@malinka/prompts/bootstrap/performance-measurement-and-optimization/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@malinka/prompts/bootstrap/performance-measurement-and-optimization/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="true", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

digraph PlanCompletionAndAdversarialReview {
    graph [
        goal="Plan Completion Detection and Adversarial Review\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `CLAUDE.md`\n- `genesis/plans/001-master-plan.md`\n\nCurrent frontier tasks:\n- Implement plan-completion detection in autodev.rs\n- Wire plan-status tracking across cycles\n- Implement 3-step adversarial review prompt\n- Generate plan-review lanes from plan registry\n- Add meta-review feedback loop (bug patterns → quality gate rules)\n- Live validation with plan completion triggering review\n\nRequired durable artifacts:\n- `outputs/plan-completion-and-adversarial-review/spec.md`\n- `outputs/plan-completion-and-adversarial-review/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: kimi-k2.5; provider: kimi; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: minimax; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@malinka/prompts/bootstrap/plan-completion-and-adversarial-review/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@malinka/prompts/bootstrap/plan-completion-and-adversarial-review/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@malinka/prompts/bootstrap/plan-completion-and-adversarial-review/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="true", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

digraph DocumentationAndOperatorRunbook {
    graph [
        goal="Documentation and Operator Runbook\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `CLAUDE.md`\n- `genesis/plans/001-master-plan.md`\n\nCurrent frontier tasks:\n- Rewrite README to reflect Fabro/Raspberry reality\n- Write operator quickstart guide\n- Write Raspberry command reference\n- Write troubleshooting guide\n- Write architecture guide for contributors\n- Audit all existing docs for accuracy\n\nRequired durable artifacts:\n- `outputs/documentation-and-operator-runbook/spec.md`\n- `outputs/documentation-and-operator-runbook/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: kimi-k2.5; provider: kimi; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: minimax; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@malinka/prompts/bootstrap/documentation-and-operator-runbook/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@malinka/prompts/bootstrap/documentation-and-operator-runbook/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@malinka/prompts/bootstrap/documentation-and-operator-runbook/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="true", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

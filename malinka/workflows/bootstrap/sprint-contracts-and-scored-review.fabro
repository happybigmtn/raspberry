digraph SprintContractsAndScoredReview {
    graph [
        goal="Sprint Contracts and Scored Review\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `CLAUDE.md`\n- `genesis/plans/001-master-plan.md`\n\nCurrent frontier tasks:\n- Verify existing contract stage works end-to-end\n- Verify existing scored review produces valid scores\n- Add contract completeness metrics to autodev report\n- Add review score distribution to autodev report\n- Run A/B test: 10 lanes with challenge stage vs 10 without\n- Decide whether to keep or remove challenge stage based on data\n\nRequired durable artifacts:\n- `outputs/sprint-contracts-and-scored-review/spec.md`\n- `outputs/sprint-contracts-and-scored-review/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: kimi-k2.5; provider: kimi; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: minimax; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@malinka/prompts/bootstrap/sprint-contracts-and-scored-review/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@malinka/prompts/bootstrap/sprint-contracts-and-scored-review/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@malinka/prompts/bootstrap/sprint-contracts-and-scored-review/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="true", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

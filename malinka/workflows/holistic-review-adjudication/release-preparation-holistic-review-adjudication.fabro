digraph ReleasePreparationHolisticReviewAdjudication {
    graph [
        goal="Final parent adjudication pass for integrated plan `release-preparation`.\n\nIntegrated child units:\n- release-preparation-ci-hardening, release-preparation-fresh-install-test, release-preparation-readme-and-changelog, release-preparation-release-binary-build, release-preparation-security-audit, release-preparation-version-bump-and-tag\n\nRe-adjudicate the Minimax and deep-review findings.\n- confirm which findings are real and blocking\n- reject weak or duplicate findings explicitly\n- preserve disagreements rather than flattening them\n- issue the final parent ship/no-ship judgment for this integrated plan\n\nRequired outputs:\n- `adjudication-verdict.md`\n- `confirmed-findings.json`\n- `rejected-findings.json`\n- `promotion.md`\n\nThis lane prefers Codex and may fall back to Opus 4.6 if needed.",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: gpt-5.4; provider: openai; }
            #polish { backend: cli; model: gpt-5.4; provider: openai; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/holistic-review-adjudication/release-preparation-holistic-review-adjudication/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/holistic-review-adjudication/release-preparation-holistic-review-adjudication/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/holistic-review-adjudication/release-preparation-holistic-review-adjudication/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="set -e\ntest -f '.raspberry/portfolio/release-preparation-holistic-review-adjudication/adjudication-verdict.md'\ntest -f '.raspberry/portfolio/release-preparation-holistic-review-adjudication/confirmed-findings.json'\ntest -f '.raspberry/portfolio/release-preparation-holistic-review-adjudication/rejected-findings.json'\ntest -f '.raspberry/portfolio/release-preparation-holistic-review-adjudication/promotion.md'\n", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

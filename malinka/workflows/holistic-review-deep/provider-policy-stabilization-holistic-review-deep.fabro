digraph ProviderPolicyStabilizationHolisticReviewDeep {
    graph [
        goal="Deep synthesis pass for integrated parent plan `provider-policy-stabilization`.\n\nIntegrated child units:\n- provider-policy-stabilization-audit-model-selection-leaks, provider-policy-stabilization-live-validation, provider-policy-stabilization-provider-health-in-status-output, provider-policy-stabilization-quota-detection-and-graceful-fallback, provider-policy-stabilization-usage-tracking\n\nRe-read the full parent state after the Minimax pass.\n- collapse duplicates and sharpen weak evidence\n- identify systemic edge cases or cross-child interactions that the first pass may have missed\n- refine the remediation plan where the first pass was broad or ambiguous\n- preserve uncertainty explicitly when evidence is incomplete\n\nRequired outputs:\n- `deep-review.md`\n- `finding-deltas.json`\n- `remediation-plan.md`\n- `promotion.md`\n\nThis lane prefers Opus 4.6 and may fall back to Codex if needed.",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: claude-opus-4-6; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/holistic-review-deep/provider-policy-stabilization-holistic-review-deep/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/holistic-review-deep/provider-policy-stabilization-holistic-review-deep/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/holistic-review-deep/provider-policy-stabilization-holistic-review-deep/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="set -e\ntest -f '.raspberry/portfolio/provider-policy-stabilization-holistic-review-deep/deep-review.md'\ntest -f '.raspberry/portfolio/provider-policy-stabilization-holistic-review-deep/finding-deltas.json'\ntest -f '.raspberry/portfolio/provider-policy-stabilization-holistic-review-deep/remediation-plan.md'\ntest -f '.raspberry/portfolio/provider-policy-stabilization-holistic-review-deep/promotion.md'\n", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

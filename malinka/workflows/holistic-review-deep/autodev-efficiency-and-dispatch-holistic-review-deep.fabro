digraph AutodevEfficiencyAndDispatchHolisticReviewDeep {
    graph [
        goal="Deep synthesis pass for integrated parent plan `autodev-efficiency-and-dispatch`.\n\nIntegrated child units:\n- autodev-efficiency-and-dispatch-add-dispatch-state-telemetry, autodev-efficiency-and-dispatch-decouple-evolve-from-dispatch-and-consume-the-budget-greedily, autodev-efficiency-and-dispatch-freeze-the-current-failure-modes-into-reproducible-tests, autodev-efficiency-and-dispatch-live-validation, autodev-efficiency-and-dispatch-make-autodev-runtime-paths-self-consistent, autodev-efficiency-and-dispatch-reconcile-stale-running-and-failed-lane-truth\n\nRe-read the full parent state after the Minimax pass.\n- collapse duplicates and sharpen weak evidence\n- identify systemic edge cases or cross-child interactions that the first pass may have missed\n- refine the remediation plan where the first pass was broad or ambiguous\n- preserve uncertainty explicitly when evidence is incomplete\n\nRequired outputs:\n- `deep-review.md`\n- `finding-deltas.json`\n- `remediation-plan.md`\n- `promotion.md`\n\nThis lane prefers Opus 4.6 and may fall back to Codex if needed.",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: claude-opus-4-6; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/holistic-review-deep/autodev-efficiency-and-dispatch-holistic-review-deep/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/holistic-review-deep/autodev-efficiency-and-dispatch-holistic-review-deep/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/holistic-review-deep/autodev-efficiency-and-dispatch-holistic-review-deep/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="set -e\ntest -f '.raspberry/portfolio/autodev-efficiency-and-dispatch-holistic-review-deep/deep-review.md'\ntest -f '.raspberry/portfolio/autodev-efficiency-and-dispatch-holistic-review-deep/finding-deltas.json'\ntest -f '.raspberry/portfolio/autodev-efficiency-and-dispatch-holistic-review-deep/remediation-plan.md'\ntest -f '.raspberry/portfolio/autodev-efficiency-and-dispatch-holistic-review-deep/promotion.md'\n", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

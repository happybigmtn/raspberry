digraph PlanCompletionAndAdversarialReviewHolisticReviewDeep {
    graph [
        goal="Deep synthesis pass for integrated parent plan `plan-completion-and-adversarial-review`.\n\nIntegrated child units:\n- plan-completion-and-adversarial-review-3-step-adversarial-review-prompt, plan-completion-and-adversarial-review-live-validation, plan-completion-and-adversarial-review-meta-review-feedback-loop, plan-completion-and-adversarial-review-plan-completion-detection, plan-completion-and-adversarial-review-registry-driven-plan-review-generation\n\nRe-read the full parent state after the Minimax pass.\n- collapse duplicates and sharpen weak evidence\n- identify systemic edge cases or cross-child interactions that the first pass may have missed\n- refine the remediation plan where the first pass was broad or ambiguous\n- preserve uncertainty explicitly when evidence is incomplete\n\nRequired outputs:\n- `deep-review.md`\n- `finding-deltas.json`\n- `remediation-plan.md`\n- `promotion.md`\n\nThis lane prefers Opus 4.6 and may fall back to Codex if needed.",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: claude-opus-4-6; provider: anthropic; }
            #polish { backend: cli; model: claude-opus-4-6; provider: anthropic; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@malinka/prompts/holistic-review-deep/plan-completion-and-adversarial-review-holistic-review-deep/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@malinka/prompts/holistic-review-deep/plan-completion-and-adversarial-review-holistic-review-deep/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@malinka/prompts/holistic-review-deep/plan-completion-and-adversarial-review-holistic-review-deep/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="set -e\ntest -f '.raspberry/portfolio/plan-completion-and-adversarial-review-holistic-review-deep/deep-review.md'\ntest -f '.raspberry/portfolio/plan-completion-and-adversarial-review-holistic-review-deep/finding-deltas.json'\ntest -f '.raspberry/portfolio/plan-completion-and-adversarial-review-holistic-review-deep/remediation-plan.md'\ntest -f '.raspberry/portfolio/plan-completion-and-adversarial-review-holistic-review-deep/promotion.md'\n", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

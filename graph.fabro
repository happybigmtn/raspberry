digraph AutodevEfficiencyAndDispatch {
    graph [
        goal="Autodev Execution Path and Dispatch Truth\n\nBootstrap the first honest reviewed slice for this frontier.\n\nInputs:\n- `README.md`\n- `SPEC.md`\n- `PLANS.md`\n- `AGENTS.md`\n- `CLAUDE.md`\n- `genesis/plans/001-master-plan.md`\n\nCurrent frontier tasks:\n- Eliminate local-only command and prompt-resolution shims from the autodev runtime path\n- Fix stale `running` and `failed` lane truth before dispatch\n- Add dispatch-state telemetry that explains why ready work did or did not run\n- Live validation: sustain 10 active lanes on rXMRbro without bootstrap validation failures\n- Live validation: at least 3 lanes land to trunk after the runtime path is boring\n\nRequired durable artifacts:\n- `outputs/autodev-efficiency-and-dispatch/spec.md`\n- `outputs/autodev-efficiency-and-dispatch/review.md`",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: cli; model: kimi-k2.5; provider: kimi; }
            #polish { backend: cli; model: MiniMax-M2.7-highspeed; provider: minimax; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@malinka/prompts/bootstrap/autodev-efficiency-and-dispatch/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@malinka/prompts/bootstrap/autodev-efficiency-and-dispatch/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@malinka/prompts/bootstrap/autodev-efficiency-and-dispatch/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="true", goal_gate=true, retry_target="polish", max_retries=0]

    start -> specify -> review -> polish -> verify
    verify -> exit [condition="outcome=success"]
    verify -> polish
}

+/// Full lifecycle test: create a Rust project, author a blueprint,
+/// render it, and verify the resulting workflow graph references
+/// correct runtime-stable asset paths.
+#[test]
+fn greenfield_rust_full_lifecycle() {
+    let temp = tempfile::tempdir().expect("tempdir");
+    let project_root = temp.path().join("lifecycle-project");
+
+    // Step 1: Bootstrap a Rust workspace
+    bootstrap_workspace_rust_project(&project_root).expect("bootstrap workspace");
+    assert!(
+        project_passes_cargo_test(&project_root),
+        "bootstrapped workspace should pass tests"
+    );
+
+    // Add a SPEC.md to provide the planning corpus
+    fs::write(
+        project_root.join("SPEC.md"),
+        r#"# Specification
+
+## Progress
+- [x] Bootstrap workspace
+- [ ] Implement feature A
+"#,
+    )
+    .expect("write SPEC.md");
+
+    // Step 2: Author blueprint for the fresh project
+    let authored = fabro_synthesis::author_blueprint_for_create(&project_root, None)
+        .expect("author blueprint for fresh project");
+
+    // Step 3: Verify blueprint structure
+    let unit = authored
+        .blueprint
+        .units
+        .iter()
+        .find(|u| u.id.contains("workspace") || u.id.contains("lifecycle"))
+        .or_else(|| authored.blueprint.units.first())
+        .expect("blueprint should have at least one unit");
+
+    assert!(
+        !unit.lanes.is_empty(),
+        "each unit should have at least one lane"
+    );
+
+    // Step 4: Render the blueprint
+    let render_report = render_blueprint(RenderRequest {
+        blueprint: &authored.blueprint,
+        target_repo: &project_root,
+    })
+    .expect("render blueprint for lifecycle project");
+
+    // Step 5: Verify manifest was created
+    assert!(
+        !render_report.written_files.is_empty(),
+        "render should produce output files"
+    );
+
+    // Step 6: Verify the target repo still compiles after rendering
+    // (render should not corrupt the project)
+    assert!(
+        project_passes_cargo_check(&project_root),
+        "project should still compile after blueprint rendering"
+    );
+}

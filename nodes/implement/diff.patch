+/// Test that the bootstrap verification gate correctly identifies
+/// when a Rust project has all required health markers.
+#[test]
+fn greenfield_rust_health_markers() {
+    let temp = tempfile::tempdir().expect("tempdir");
+    let project_root = temp.path().join("health-markers");
+
+    // Bootstrap a complete Rust project
+    bootstrap_workspace_rust_project(&project_root).expect("bootstrap workspace");
+
+    // Verify all health markers
+    let cargo_toml = project_root.join("Cargo.toml");
+    assert!(cargo_toml.is_file(), "Cargo.toml must exist");
+
+    // Check that the project has a valid workspace or package
+    let cargo_metadata = Command::new("cargo")
+        .args(["metadata", "--no-deps", "--manifest-path"])
+        .arg(&cargo_toml)
+        .output();
+
+    assert!(
+        cargo_metadata.is_ok(),
+        "`cargo metadata` should execute"
+    );
+    assert!(
+        cargo_metadata.as_ref().expect("cargo metadata result").status.success(),
+        "`cargo metadata` should succeed"
+    );
+
+    // Verify source files exist
+    let lib_rs = project_root
+        .join("crates")
+        .join("my-library")
+        .join("src")
+        .join("lib.rs");
+    let main_rs = project_root
+        .join("crates")
+        .join("my-binary")
+        .join("src")
+        .join("main.rs");
+    assert!(lib_rs.is_file(), "lib.rs must exist");
+    assert!(main_rs.is_file(), "main.rs must exist");
+
+    // Verify compilation succeeds
+    assert!(
+        project_compiles(&project_root),
+        "project should compile"
+    );
+}

+/// Test that bootstrap verification logic correctly identifies
+/// a healthy Rust project (Cargo.toml + valid structure).
+#[test]
+fn greenfield_rust_bootstrap_verify() {
+    let temp = tempfile::tempdir().expect("tempdir");
+    let project_root = temp.path().join("verify-target");
+
+    // Bootstrap a valid Rust project
+    bootstrap_minimal_rust_project(&project_root).expect("bootstrap should succeed");
+
+    // Verify the bootstrap health markers
+    assert!(
+        project_root.join("Cargo.toml").is_file(),
+        "package manifest must exist"
+    );
+
+    // Cargo metadata should work
+    let cargo_result = Command::new("cargo")
+        .args(["metadata", "--no-deps", "--manifest-path"])
+        .arg(project_root.join("Cargo.toml"))
+        .output();
+
+    assert!(
+        cargo_result.is_ok() && cargo_result.unwrap().status.success(),
+        "`cargo metadata` should succeed for valid Rust project"
+    );
+}
+
+/// Test that an invalid Rust project (missing Cargo.toml) fails
+/// bootstrap verification gracefully.
+#[test]
+fn greenfield_rust_invalid_project_rejected() {
+    let temp = tempfile::tempdir().expect("tempdir");
+    let project_root = temp.path().join("invalid-project");
+
+    // Create only a source file without Cargo.toml
+    let src_dir = project_root.join("src");
+    fs::create_dir_all(&src_dir).expect("create src dir");
+    fs::write(src_dir.join("main.rs"), "fn main() {}")
+        .expect("write main.rs");
+
+    // Verify Cargo.toml is missing
+    assert!(
+        !project_root.join("Cargo.toml").exists(),
+        "invalid project should not have Cargo.toml"
+    );
+
+    // `cargo metadata` should fail or indicate no package
+    let cargo_result = Command::new("cargo")
+        .args(["metadata", "--no-deps", "--manifest-path"])
+        .arg(project_root.join("Cargo.toml"))
+        .output();
+
+    // Should either fail to run or return non-success
+    assert!(
+        cargo_result.is_err()
+            || !cargo_result
+                .expect("cargo metadata should return result")
+                .status
+                .success(),
+        "cargo metadata should fail for invalid Rust project"
+    );
+}

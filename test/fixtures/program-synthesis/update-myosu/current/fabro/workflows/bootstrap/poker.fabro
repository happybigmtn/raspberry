digraph Poker {
    graph [
        goal="Reconcile the poker lane with current doctrine and reviewed artifact\nexpectations.\n",
        model_stylesheet="
            *       { backend: cli; }
            #review { backend: api; model: gpt-5.4; provider: openai; }
            #polish { backend: api; model: gpt-5.4; provider: openai; }
        "
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    specify [label="Specify", prompt="@../../prompts/bootstrap/poker/plan.md", reasoning_effort="high"]
    review  [label="Review", prompt="@../../prompts/bootstrap/poker/review.md", reasoning_effort="high"]
    polish  [label="Polish", prompt="@../../prompts/bootstrap/poker/polish.md", reasoning_effort="medium"]
    verify  [label="Verify", shape=parallelogram, script="test -f outputs/outputs/games/poker/spec.md && test -f outputs/outputs/games/poker/review.md", goal_gate=true, max_retries=0]

    start -> specify -> review -> polish -> verify -> exit
}
